{
  "name": "backend",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "openapi:generate": "tsc -p tsconfig.build.json >/dev/null && node scripts/generate-openapi.mjs && pnpm exec biome format --write openapi.json",
    "openapi:print": "tsc -p tsconfig.build.json >/dev/null && node scripts/generate-openapi.mjs --stdout",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:migrate:runtime": "node dist/db/migrate.js",
    "legacy:migrate": "tsx src/scripts/migrate-legacy-docshare.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1019.0",
    "@aws-sdk/s3-request-presigner": "^3.1019.0",
    "@hono/node-server": "^1.13.8",
    "@hono/swagger-ui": "^0.6.1",
    "@hono/zod-openapi": "^1.2.4",
    "@sendgrid/mail": "^8.1.5",
    "better-auth": "^1.5.6",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.9",
    "pg": "^8.13.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.19.3"
  }
}
